datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

enum TipoDocumento {
  CC
  CE
  PASAPORTE
  NIT
}

enum EstadoServicio {
  NUEVO
  ASIGNADO
  TERMINADO
  CERRADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  FALLIDO
}

enum NivelTecnico {
  MADERA
  BRONCE
  PLATA
  ORO
}

model CategoriaServicio {
  id        String           @id @default(uuid())
  nombre    String           @unique
  slug      String           @unique
  createdAt DateTime         @default(now()) @map("created_at")

  productos ProductoServicioCategoria[]

  @@map("categorias_servicio")
}

model ProductoServicio {
  id              String           @id @default(uuid())
  nombre          String
  descripcion     String
  slug            String           @unique
  precioBase      Float            @map("precio_base")
  imagenUrl       String?          @map("imagen_url")
  incluye         String?
  noIncluye       String?
  notaInformativa String?          @map("nota_informativa")
  soportaCantidad Boolean          @default(false) @map("soporta_cantidad")
  activo          Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  categorias     ProductoServicioCategoria[]
  reglasPrecio   ReglaPrecio[]
  solicitudes    Servicio[]

  @@map("productos_servicio")
  @@index([activo])
  @@index([slug])
}

model ProductoServicioCategoria {
  productoId  String           @map("producto_id")
  categoriaId String           @map("categoria_id")
  producto    ProductoServicio @relation(fields: [productoId], references: [id], onDelete: Cascade)
  categoria   CategoriaServicio @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([productoId, categoriaId])
  @@map("productos_servicio_categorias")
}

model ReglaPrecio {
  id              String           @id @default(uuid())
  productoId      String           @map("producto_id")
  producto        ProductoServicio @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tipo            String           // "cantidad" | "boolean_extra"
  clave           String           // "retirar_elemento"
  etiqueta        String
  precioAdicional Float?           @map("precio_adicional")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@map("reglas_precio")
  @@index([productoId])
}

model Usuario {
  id            String         @id @default(uuid())
  nombre        String
  apellido      String
  tipoDocumento TipoDocumento
  numDocumento  String         @unique
  correo        String         @unique
  celular       String
  contrasena    String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  clientePerfil       Cliente?
  tecnicoPerfil       Tecnico?
  serviciosCliente    Servicio[] @relation("ServicioCliente")
  serviciosTecnico    Servicio[] @relation("ServicioTecnico")
  refreshTokens       RefreshToken[]
  mensajesEnviados    Mensaje[]  @relation("MensajeEmisor")

  @@map("usuarios")
  @@index([correo])
  @@index([numDocumento])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @map("token")
  usuarioId String   @map("usuario_id")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
  @@index([token])
  @@index([usuarioId])
}

model Cliente {
  id        String     @id @map("id")
  usuario   Usuario    @relation(fields: [id], references: [id], onDelete: Cascade)
  direcciones Direccion[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("clientes")
}

model Direccion {
  id           String  @id @default(uuid())
  clienteId    String @map("cliente_id")
  cliente      Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  direccion    String
  latitud      Float
  longitud     Float
  esPrincipal  Boolean @default(false) @map("es_principal")
  eliminadoEn  DateTime? @map("eliminado_en")

  servicios Servicio[]

  @@map("direcciones")
  @@index([clienteId])
  @@index([eliminadoEn])
}

model Tecnico {
  id                String         @id @map("id")
  usuario           Usuario        @relation(fields: [id], references: [id], onDelete: Cascade)
  disponibilidad    Boolean        @default(true)
  latitud           Float?
  longitud          Float?
  radioCoberturaKm  Float          @default(10.0) @map("radio_cobertura_km")
  nivel             NivelTecnico   @default(PLATA)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@map("tecnicos")
  @@index([disponibilidad])
}

model Servicio {
  id                  String             @id @default(uuid())
  clienteId           String             @map("cliente_id")
  cliente             Usuario            @relation("ServicioCliente", fields: [clienteId], references: [id])
  direccionId         String             @map("direccion_id")
  direccion           Direccion          @relation(fields: [direccionId], references: [id])
  descripcion         String
  estado              EstadoServicio     @default(NUEVO)
  detallesCompletado  String?            @map("detalles_completado")
  tecnicoId           String?            @map("tecnico_id")
  tecnico             Usuario?           @relation("ServicioTecnico", fields: [tecnicoId], references: [id])
  productoId          String?            @map("producto_id")
  producto            ProductoServicio?  @relation(fields: [productoId], references: [id])
  cantidad            Int?               @default(1)
  opciones            Json?
  precioBase          Float?             @map("precio_base")
  subtotal            Float?
  tarifaServicio      Float?             @map("tarifa_servicio")
  total               Float?
  pago                Pago?
  imagenes            Imagen[]
  mensajes            Mensaje[]
  calificacion         Int?
  comentarioCalificacion String?          @map("comentario_calificacion")
  fechaCalificacion    DateTime?          @map("fecha_calificacion")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  @@map("servicios")
  @@index([estado])
  @@index([clienteId])
  @@index([tecnicoId])
  @@index([productoId])
}

model Imagen {
  id          String                 @id @default(uuid())
  url         String
  servicioId  String?                @map("servicio_id")
  servicio    Servicio?              @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now()) @map("created_at")

  @@map("imagenes")
  @@index([servicioId])
}

model Pago {
  id          String             @id @default(uuid())
  servicioId  String             @unique @map("servicio_id")
  servicio    Servicio           @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  monto       Float
  estado      EstadoPago         @default(PENDIENTE)
  metodoPago  String?            @map("metodo_pago")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("pagos")
  @@index([servicioId])
  @@index([estado])
}

model Mensaje {
  id          String   @id @default(uuid())
  servicioId  String   @map("servicio_id")
  servicio    Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  emisorId    String   @map("emisor_id")
  emisor      Usuario  @relation("MensajeEmisor", fields: [emisorId], references: [id])
  contenido   String
  leido       Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("mensajes")
  @@index([servicioId])
  @@index([emisorId])
  @@index([createdAt])
}
