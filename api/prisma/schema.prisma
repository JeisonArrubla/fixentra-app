datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

enum TipoDocumento {
  CC
  CE
  PASAPORTE
  NIT
}

enum EstadoSolicitud {
  NUEVA
  ASIGNADA
  TERMINADA
  COMPLETADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  FALLIDO
}

model Usuario {
  id            String         @id @default(uuid())
  nombre        String
  apellido      String
  tipoDocumento TipoDocumento
  numDocumento  String         @unique
  correo        String         @unique
  celular       String
  contrasena    String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  clientePerfil    Cliente?
  tecnicoPerfil   Tecnico?
  solicitudesCliente SolicitudServicio[] @relation("SolicitudCliente")
  solicitudesTecnico  SolicitudServicio[] @relation("SolicitudTecnico")

  @@map("usuarios")
  @@index([correo])
  @@index([numDocumento])
}

model Cliente {
  id        String     @id @map("id")
  usuario   Usuario    @relation(fields: [id], references: [id], onDelete: Cascade)
  direcciones Direccion[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("clientes")
}

model Direccion {
  id           String  @id @default(uuid())
  clienteId    String @map("cliente_id")
  cliente      Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  direccion    String
  latitud      Float
  longitud     Float
  esPrincipal  Boolean @default(false) @map("es_principal")

  solicitudes SolicitudServicio[]

  @@map("direcciones")
  @@index([clienteId])
}

model Tecnico {
  id                String    @id @map("id")
  usuario           Usuario   @relation(fields: [id], references: [id], onDelete: Cascade)
  disponibilidad      Boolean   @default(true)
  latitud           Float?
  longitud          Float?
  radioCoberturaKm  Float     @default(10.0) @map("radio_cobertura_km")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("tecnicos")
  @@index([disponibilidad])
}

model SolicitudServicio {
  id           String          @id @default(uuid())
  clienteId    String          @map("cliente_id")
  cliente      Usuario         @relation("SolicitudCliente", fields: [clienteId], references: [id])
  direccionId  String          @map("direccion_id")
  direccion    Direccion      @relation(fields: [direccionId], references: [id])
  descripcion  String
  estado       EstadoSolicitud @default(NUEVA)
  detallesCompletado String?       @map("detalles_completado")
  tecnicoId    String?        @map("tecnico_id")
  tecnico      Usuario?       @relation("SolicitudTecnico", fields: [tecnicoId], references: [id])
  pago         Pago?
  imagenes     Imagen[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("solicitudes_servicios")
  @@index([estado])
  @@index([clienteId])
  @@index([tecnicoId])
}

model Imagen {
  id          String    @id @default(uuid())
  url         String
  solicitudId String?   @map("solicitud_id")
  solicitud   SolicitudServicio? @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("imagenes")
  @@index([solicitudId])
}

model Pago {
  id           String     @id @default(uuid())
  solicitudId  String     @unique @map("solicitud_id")
  solicitud    SolicitudServicio @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  monto        Float
  estado       EstadoPago @default(PENDIENTE)
  metodoPago   String?    @map("metodo_pago")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("pagos")
  @@index([solicitudId])
  @@index([estado])
}